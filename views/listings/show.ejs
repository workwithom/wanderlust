<% layout("/layouts/boilerplate") %>
<script>
    const mapTokenKey = '<%= process.env.MAP_TOKEN %>';
    const listing = JSON.parse('<%- JSON.stringify(listing) %>');
</script>

<div class="container-fluid show-page">
    <div class="row">
        <!-- Left Column - Main Content -->
        <div class="col-lg-8">
            <!-- Title and Ratings Section -->
            <div class="listing-header">
                <h2 class="listing-title"><%= listing.title %></h2>
                <div class="d-flex justify-content-between align-items-center flex-wrap mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <% const avgRating = listing.reviews.length ? 
                            Math.round((listing.reviews.reduce((sum, review) => sum + Number(review.rating), 0) / listing.reviews.length) * 10) / 10
                            : 0 %>
                        <p class="starability-result mb-0" data-rating="<%= Math.round(avgRating) %>"></p>
                        <span class="text-muted">
                            <%= avgRating %> (<%= listing.reviews.length %> <%= listing.reviews.length === 1 ? 'review' : 'reviews' %>)
                        </span>
                    </div>
                    <div class="listing-location">
                        <i class="fa-solid fa-location-dot"></i>
                        <%= listing.location %>, <%= listing.country %>
                    </div>
                </div>
            </div>

            <!-- Main Image -->
            <div class="listing-image-container">
                <img src="<%= listing.image.url.replace('/upload/', '/upload/q_70,f_auto/') %>" class="listing-main-image" alt="<%= listing.title %>">
            </div>

            <!-- Host Info and Description Section -->
            <div class="listing-details">
                <div class="host-section">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="host-avatar">
                            <i class="fa-solid fa-user-circle fa-2x"></i>
                        </div>
                        <div>
                            <h5 class="mb-1">Hosted by <%= listing.owner ? listing.owner.username : "Unknown Owner" %></h5>
                            <p class="text-muted mb-0"><i class="fa-solid fa-medal"></i> Superhost</p>
                        </div>
                    </div>
                </div>

                <div class="description-section">
                    <h4>About this place</h4>
                    <p class="listing-description"><%= listing.description %></p>
                </div>

                <div class="price-section">
                    <h4>Price Details</h4>
                    <div class="price-tag">
                        <span class="price">₹ <%= listing.price.toLocaleString("en-IN") %></span>
                        <span class="per-night">/night</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column - Map and Reviews -->
        <div class="col-lg-4">
            <div class="sticky-sidebar">
                <!-- Map Section -->
                <div class="map-section mb-4">
                    <h4>Where you'll be</h4>
                    <div id="map"></div>
                </div>

                <!-- Reviews Section -->
                <div class="reviews-section">
                    <h4>Guest Reviews</h4>
                    <div class="reviews-container">
                        <% if (listing.reviews.length > 0) { %>
                            <% listing.reviews.forEach(review => { %>
                                <div class="review-card">
                                    <div class="review-header">
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="fa-solid fa-user-circle"></i>
                                            <h6 class="mb-0">@<%= review.author.username %></h6>
                                        </div>
                                        <small class="text-muted">
                                            <%= new Date(review.createdAt).toLocaleDateString('en-US', { 
                                                year: 'numeric', 
                                                month: 'long', 
                                                day: 'numeric' 
                                            }) %>
                                        </small>
                                    </div>
                                    <div class="review-body">
                                        <p class="starability-result" data-rating="<%= review.rating %>"></p>
                                        <p class="review-text"><%= review.comment %></p>
                                    </div>
                                    <% if (currentUser && review.author._id.equals(currentUser._id)) { %>
                                        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mt-2">
                                            <button class="btn btn-sm btn-outline-danger">Delete Review</button>
                                        </form>
                                    <% } %>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-muted">No reviews yet. Be the first to review!</p>
                        <% } %>
                    </div>

                    <!-- Review Form -->
                    <% if(currentUser) { %>
                        <div class="review-form-section mt-4">
                            <h5>Leave a Review</h5>
                            <form method="POST" action="/listings/<%= listing._id %>/reviews" class="needs-validation" novalidate>
                                <fieldset class="starability-slot mb-3">
                                    <legend>Rating:</legend>
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                                    <input type="radio" id="rate1" name="review[rating]" value="1" />
                                    <label for="rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="rate2" name="review[rating]" value="2" />
                                    <label for="rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="rate3" name="review[rating]" value="3" />
                                    <label for="rate3" title="Average">3 stars</label>
                                    <input type="radio" id="rate4" name="review[rating]" value="4" />
                                    <label for="rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="rate5" name="review[rating]" value="5" />
                                    <label for="rate5" title="Amazing">5 stars</label>
                                </fieldset>
                                <div class="mb-3">
                                    <label for="comment" class="form-label">Your Review</label>
                                    <textarea class="form-control" name="review[comment]" id="comment" rows="3" required></textarea>
                                </div>
                                <button type="submit" class="btn btn-success">Submit Review</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Edit/Delete Buttons for Owner -->
        <% if (listing.owner && currentUser && listing.owner._id.toString() === currentUser._id.toString()) { %>
            <div class="owner-actions">
                <a href="/listings/<%= listing._id %>/edit" class="btn edit-btn">
                    <i class="fa-solid fa-edit"></i> Edit Listing
                </a>
                <form method="post" action="/listings/<%= listing._id %>?_method=delete" class="d-inline">
                    <button class="btn delete-btn">
                        <i class="fa-solid fa-trash"></i> Delete Listing
                    </button>
                </form>
            </div>
        <% } %>    </div>
</div>

<div class="inspiration-section container">
    <h2 class="inspiration-title">Inspiration for future getaways</h2>
    <div class="inspiration-tabs">
        <a href="#" class="inspiration-tab active">Unique stays</a>
        <a href="#" class="inspiration-tab">Categories</a>
    </div>

    <div class="inspiration-grid">
        <div class="inspiration-item">
            <div class="inspiration-location">Yurt Rentals</div>
            <div class="inspiration-country">United States</div>
        </div>
        <div class="inspiration-item">
            <div class="inspiration-location">Farm Houses</div>
            <div class="inspiration-country">United Kingdom</div>
        </div>
        <div class="inspiration-item">
            <div class="inspiration-location">Castle Rentals</div>
            <div class="inspiration-country">France</div>
        </div>
        <div class="inspiration-item">
            <div class="inspiration-location">Houseboats</div>
            <div class="inspiration-country">Netherlands</div>
        </div>
        <div class="inspiration-item">
            <div class="inspiration-location">Luxury Cabins</div>
            <div class="inspiration-country">Canada</div>
        </div>
        <div class="inspiration-item">
            <div class="inspiration-location">Treehouse Stays</div>
            <div class="inspiration-country">Costa Rica</div>
        </div>
        <div class="inspiration-item">
            <div class="inspiration-location">Beach Houses</div>
            <div class="inspiration-country">Australia</div>
        </div>
        <div class="inspiration-item">
            <div class="inspiration-location">Mountain Chalets</div>
            <div class="inspiration-country">Switzerland</div>
        </div>
    </div>
</div>

<script src="/js/map.js"></script>